# Data
DATA__DIR=./data
DB__URL=sqlite:///./data/app.db
ETL__DOCUMENT_PATH=data/rag-document.md
FAISS__DIR=./data

# LLM (OpenAI-compatible custom provider; full API base, e.g. .../v1 or .../api/v1)
LLM__BASE_URL=https://your-llm-provider.example/v1
LLM__API_KEY=
LLM__MODEL=your-chat-model-name
LLM__SUMMARIZATION_MODEL=your-summarization-model-name
LLM__EMBEDDING_MODEL=your-embedding-model-name

# Logging
LOG__LEVEL=INFO
LOG__FORMAT=JSON

# App
APP__CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174"]
