# Data
DATA__DIR=./data
DB__URL=sqlite:///./data/app.db

# LLM (OpenAI-compatible custom provider)
LLM__BASE_URL=https://your-llm-provider.example/v1
LLM__API_KEY=
LLM__MODEL=your-chat-model-name
LLM__ROUTER_MODEL=your-router-model-name
LLM__EMBEDDING_MODEL=your-embedding-model-name

# Logging
LOG__LEVEL=INFO
LOG__FORMAT=json

# App
APP__CORS_ORIGINS=["http://localhost:5173"]

# Telegram (stage 8)
TELEGRAM__BOT_TOKEN=
